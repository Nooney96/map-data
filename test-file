<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        html, body, #map { height: 100%; width: 100%; margin: 0; padding: 0; }
        
        /* The Floating Filter Bar */
        #filter-bar {
            position: absolute;
            top: 10px;
            left: 50px;
            z-index: 1000;
            background: white;
            padding: 10px;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.3);
            display: flex;
            gap: 5px;
        }
        button { cursor: pointer; padding: 5px 10px; border: 1px solid #ccc; border-radius: 4px; background: #f9f9f9; }
        button.active { background: #4CAF50; color: white; border-color: #4CAF50; }
    </style>
</head>
<body>

    <div id="filter-bar">
        <button class="active" onclick="switchCategory('playparks', this)">🛝 Playparks</button>
        <button onclick="switchCategory('museums', this)">🏛️ Museums</button>
        <button onclick="switchCategory('indoors', this)">🏠 Indoors</button>
    </div>

    <div id="map"></div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src='https://api.mapbox.com/mapbox.js/plugins/leaflet-omnivore/v0.3.1/leaflet-omnivore.min.js'></script>

    <script>
        var map = L.map('map').setView([54.60, -6.60], 8);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

        var currentLayer;
        var baseUrl = 'https://raw.githubusercontent.com/Nooney96/map-data/main/tyrone-';

        function switchCategory(category, btn) {
            // 1. Clear the old layer if it exists
            if (currentLayer) { map.removeLayer(currentLayer); }

            // 2. Update button styles
            var buttons = document.querySelectorAll('button');
            buttons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            // 3. Load the new KML file
            // Note: Use the proxy we used before if you face "Forbidden" errors
            var kmlUrl = 'https://api.allorigins.win/raw?url=' + encodeURIComponent(baseUrl + category + '.kml');

            currentLayer = omnivore.kml(kmlUrl)
                .on('ready', function() {
                    map.fitBounds(this.getBounds());
                })
                .addTo(map);
        }

        // Load Playparks by default on start
        window.onload = function() {
            switchCategory('playparks', document.querySelector('button'));
        };
    </script>
</body>
</html>
